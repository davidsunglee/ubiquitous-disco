{
  "name": "ubiquitous-disco",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @bb/web dev",
    "dev:web": "pnpm --filter @bb/web dev",
    "test": "vitest run",
    "test:e2e": "pnpm --filter @bb/web test:e2e",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome ci .",
    "format": "biome check . --write",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm test:e2e",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.8.0",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "husky": "^9.1.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
